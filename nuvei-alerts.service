[Unit]
Description=Nuvei Chargeback Alert Webhook
After=network.target

[Service]
Type=simple
User=deploy
WorkingDirectory=/home/deploy/nuvei-alerts
ExecStart=/usr/bin/node src/server.js
Restart=on-failure
RestartSec=5
EnvironmentFile=/home/deploy/nuvei-alerts/.env

[Install]
WantedBy=multi-user.target
