# Server
PORT=3200

# Nuvei — your merchant secret key for checksum verification
# Found in Nuvei Control Panel under Settings > Merchant Secret Key
NUVEI_MERCHANT_SECRET=your_merchant_secret_key_here

# SendGrid
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxx
SENDGRID_FROM="Nuvei Alerts <alerts@yourdomain.com>"

# Comma-separated list of email addresses to receive alerts
ALERT_RECIPIENTS=person1@example.com,person2@example.com,person3@example.com
